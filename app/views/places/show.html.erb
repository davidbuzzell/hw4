<h1><%= @place["name"] %></h1>

<% for entry in @entries %>
  <h2><%= entry["title"] %></h2>
  <p><%= entry["occurred_on"] %></p>
  <p><%= entry["description"] %></p>
  <br />
<% end %>

<p>
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary btn-lg">New Entry</a>
</p>

<p>
  <a href="/places"><b>Back to All Places</b></a>
</p>

<form action="/places/<%= @place["id"] %>" method="post">
  <input type="hidden" name="_method" value="delete">
  <a href="/places" class="btn btn-secondary">Delete Place</a>
</form>